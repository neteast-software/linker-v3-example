      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(linker_v3_example_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(linker_v3_example_http_requests_total[5m])), 1)",
          "legendFormat": "5xx"
        }
      ],
      "title": "HTTP 错误率",
      "type": "timeseries"
    },
